{
  "name": "wishlist-tester",
  "version": "1.0.0",
  "description": "Developer tool for testing wishlist apps on Shopify - supports API and UI (Playwright) test automation",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 5273\" \"tsx watch server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "cli": "tsx cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@xyflow/react": "^12.10.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonpath-plus": "^10.2.0",
    "playwright": "^1.49.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "codemirror": "^6.0.1",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^27.0.1",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
